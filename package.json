{
  "name": "prototoy",
  "version": "0.2.1",
  "description": "UI mockup and wireframe organizer",
  "homepage": "https://robog.net/docs/prototoy",
  "repository": {
    "type": "git",
    "url": "https://github.com/robog-two/prototoy.git"
  },
  "desktopName": "prototoy.desktop",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "icons": "node build/generate-icons.js",
    "package": "npm run icons && electron-vite build && electron-builder",
    "lint": "eslint . --ext .ts,.tsx,.js --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "chokidar": "^5.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "gifenc": "^1.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@emotion/babel-plugin": "^11.13.0",
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^29.7.0",
    "@storybook/addon-coverage": "^3.0.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/builder-vite": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/jest": "^29.5.11",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.11.1",
    "electron-vite": "^6.0.0-beta.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.8.3",
    "prettier-config-airbnb": "^1.0.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
